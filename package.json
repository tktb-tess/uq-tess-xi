{
  "name": "uq-tess-xi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "node .prebuilds/xml-generate.ts && vite build",
    "lbuild": "rm -rf .vercel && node .prebuilds/xml-generate.ts && vite build",
    "preview": "vite preview",
    "build-preview": "rm -rf .vercel && node .prebuilds/xml-generate.ts && vite build && vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@shikijs/rehype": "^3.23.0",
    "@sveltejs/adapter-vercel": "~6.3.3",
    "@sveltejs/kit": "~2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tktb-tess/my-zod-schema": "^0.4.1",
    "@tktb-tess/util-fns": "^0.12.1",
    "@types/hast": "^3.0.4",
    "@types/jsdom": "^27.0.0",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.5.2",
    "@types/papaparse": "^5.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "lightningcss": "^1.32.0",
    "mdast-util-directive": "^3.1.0",
    "mdast-util-to-hast": "^13.2.1",
    "neverthrow": "^8.2.0",
    "papaparse": "^5.5.3",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "redis": "^5.11.0",
    "rehype-katex": "^7.0.1",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "type-fest": "^5.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "unified": "^11.0.5",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
